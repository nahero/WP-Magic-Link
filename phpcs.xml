<?xml version="1.0"?>
<ruleset name="MSV Magic Link Auth">
    <description>Coding standard for the MSV Magic Link Auth plugin.</description>

    <file>msv-magic-link-auth.php</file>

    <arg value="sp"/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>

    <config name="minimum_supported_wp_version" value="7.0"/>
    <config name="testVersion" value="8.4-"/>

    <rule ref="WordPress-Extra"/>
    <rule ref="WordPress-Docs"/>
    <rule ref="PHPCompatibilityWP"/>
</ruleset>
